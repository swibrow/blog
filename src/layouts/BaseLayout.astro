---
import "@/styles/global.css";
import SEO from "@components/SEO.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title = "Samuel Wibrow — SRE / Platform Engineer",
  description = "Notes on Kubernetes, AWS, platform engineering, and SRE work from a senior platform engineer based in Zurich.",
  image,
  type = "website",
  publishedTime,
  modifiedTime,
  tags,
  noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
    />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Samuel Wibrow"
      href="/rss.xml"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script src="https://insights.wibrow.dev/api/script.js" data-site-id="69fb55d8a59b" defer></script>

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme = stored === "light" ? "light" : "dark";
        document.documentElement.classList.add(theme);
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
