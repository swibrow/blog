---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@components/layout/SectionHeading.astro";
import ToolsList from "@components/react/ToolsList";
import { tools, categories } from "@/data/tools";

const description =
  "Curated CLI and terminal tools I use daily: Ghostty, fzf, ripgrep, kubectl, k9s, jq, tmux, and more. Categorised and filterable.";
---

<BaseLayout title="Tools — Samuel Wibrow" description={description}>
  <SectionHeading title="tools" subtitle="A small collection of tools to make me feel like a wizard.">
    <ToolsList tools={tools} categories={categories} client:only="react" />

    <noscript>
      <a
        href="https://github.com/swibrow/dotfiles"
        target="_blank"
        rel="noopener noreferrer"
        class="mb-6 block rounded-lg border p-4"
        style="background-color: var(--ctp-mantle); border-color: var(--ctp-surface0);"
      >
        <div class="flex items-center gap-3">
          <span class="text-2xl">⚙️</span>
          <div>
            <h2 class="mb-0.5 text-lg font-bold" style="color: var(--ctp-yellow);">
              Dotfiles
            </h2>
            <p class="mb-0 text-sm" style="color: var(--ctp-subtext1);">
              My configuration files and setup scripts — the source of truth
            </p>
          </div>
        </div>
      </a>

      <div class="grid gap-3 sm:grid-cols-2">
        {
          tools.map((tool) => (
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block rounded-lg border p-4"
              style="background-color: var(--ctp-mantle); border-color: var(--ctp-surface0);"
            >
              <h2 class="mb-0.5 text-base font-bold" style="color: var(--ctp-text);">
                {tool.name}
              </h2>
              <p class="mb-0 text-sm" style="color: var(--ctp-subtext1);">
                {tool.description}
              </p>
              <span class="mt-2 inline-block font-mono text-xs" style="color: var(--ctp-blue);">
                {tool.category.toLowerCase()}
              </span>
            </a>
          ))
        }
      </div>
    </noscript>
  </SectionHeading>
</BaseLayout>
