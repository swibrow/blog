---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@components/home/Hero.astro";
import Card from "@components/ui/Card.astro";
import { projects } from "@/data/projects";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featuredProjects = projects
  .filter((p) => p.links && p.links.length > 0)
  .slice(0, 4);

const description =
  "Senior SRE / Platform Engineer based in Zurich. Posts on Kubernetes, AWS, Terraform, and platform engineering — plus side projects, tools, and TIL notes.";

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Samuel Wibrow",
  url: "https://samuel.wibrow.net",
  description,
  author: {
    "@type": "Person",
    name: "Samuel Wibrow",
    url: "https://samuel.wibrow.net/about",
  },
};
---

<BaseLayout title="Samuel Wibrow — SRE / Platform Engineer" description={description}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(websiteJsonLd)}
  />

  <Hero />

  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="mb-8 flex items-center justify-between">
      <h2 class="font-mono text-2xl font-bold" style="color: var(--ctp-green);">
        ~/recent-posts
      </h2>
      <a href="/posts" class="font-mono text-sm" style="color: var(--ctp-lavender);">
        view all →
      </a>
    </div>
    <div class="flex flex-col gap-4">
      {
        posts.map((post) => (
          <Card href={`/posts/${post.id}`}>
            <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="font-mono text-base font-bold" style="color: var(--ctp-blue);">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="mt-1 text-sm" style="color: var(--ctp-subtext1);">
                    {post.data.description}
                  </p>
                )}
              </div>
              <time
                class="shrink-0 font-mono text-xs"
                style="color: var(--ctp-subtext0);"
                datetime={post.data.date.toISOString()}
              >
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>
            {post.data.tags.length > 0 && (
              <div class="mt-2 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span
                    class="rounded px-1.5 py-0.5 font-mono text-xs"
                    style="background-color: var(--ctp-surface0); color: var(--ctp-subtext0);"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </Card>
        ))
      }
    </div>
  </section>

  <section
    class="mx-auto max-w-6xl px-4 py-20"
    style="border-top: 1px solid var(--ctp-surface0);"
  >
    <div class="mb-8 flex items-center justify-between">
      <h2 class="font-mono text-2xl font-bold" style="color: var(--ctp-green);">
        ~/projects
      </h2>
      <a href="/projects" class="font-mono text-sm" style="color: var(--ctp-lavender);">
        view all →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        featuredProjects.map((project) => (
          <Card>
            <h3 class="mb-1 font-mono text-base font-bold" style="color: var(--ctp-blue);">
              {project.name}
            </h3>
            <p class="mb-2 text-sm" style="color: var(--ctp-text);">
              {project.description}
            </p>
            {project.links && (
              <div class="flex flex-wrap gap-3">
                {project.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono text-xs hover:underline"
                    style="color: var(--ctp-lavender);"
                  >
                    {link.label} →
                  </a>
                ))}
              </div>
            )}
          </Card>
        ))
      }
    </div>
  </section>
</BaseLayout>
