---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Masthead from "@components/home/Masthead.astro";
import StatCard from "@components/home/StatCard.astro";
import ClusterMetrics from "@components/react/ClusterMetrics";
import { fetchGitHubStats } from "@/lib/github";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latestPost = posts[0];
const recentPosts = posts.slice(0, 5);

const gh = await fetchGitHubStats();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

const description =
  "Senior SRE / Platform Engineer based in Zurich. Posts on Kubernetes, AWS, Terraform, and platform engineering — plus side projects, tools, and TIL notes.";

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Samuel Wibrow",
  url: Astro.site!.toString(),
  description,
  author: {
    "@type": "Person",
    name: "Samuel Wibrow",
    url: new URL("/about", Astro.site).toString(),
  },
};
---

<BaseLayout title="Samuel Wibrow — SRE / Platform Engineer" description={description}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(websiteJsonLd)}
  />

  <Masthead />

  {
    gh && (
      <section class="mx-auto max-w-6xl px-4 py-10">
        <h2 class="mb-6 font-mono text-xl font-bold" style="color: var(--ctp-green);">
          ~/github
        </h2>
        <div class="grid grid-cols-2 gap-4">
          {gh.contributions !== null && (
            <StatCard
              label="contributions (1y)"
              value={gh.contributions.toLocaleString("en-US")}
            />
          )}
          <StatCard label="public repos" value={String(gh.publicRepos)} />
          {gh.contributions === null && (
            <StatCard label="stack" value="Go / Py / TS" small />
          )}
        </div>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {gh.latestPush && (
            <StatCard
              label="latest push"
              value={gh.latestPush.repo}
              sub={formatDate(new Date(gh.latestPush.date))}
              subIso={gh.latestPush.date}
              small
              href={`https://github.com/swibrow/${gh.latestPush.repo}`}
            />
          )}
          {latestPost && (
            <StatCard
              label="latest post"
              value={latestPost.data.title}
              sub={formatDate(latestPost.data.date)}
              small
              href={`/posts/${latestPost.id}`}
            />
          )}
        </div>
      </section>
    )
  }

  <section
    class="mx-auto max-w-6xl px-4 py-10"
    style="border-top: 1px solid var(--ctp-surface0);"
  >
    <h2 class="mb-6 font-mono text-xl font-bold" style="color: var(--ctp-green);">
      ~/cluster
    </h2>
    <ClusterMetrics client:load />
  </section>

  <section
    class="mx-auto max-w-6xl px-4 py-10"
    style="border-top: 1px solid var(--ctp-surface0);"
  >
    <div class="mb-4 flex items-center justify-between">
      <h2 class="font-mono text-xl font-bold" style="color: var(--ctp-green);">
        ~/recent-posts
      </h2>
      <a href="/posts" class="font-mono text-sm" style="color: var(--ctp-lavender);">
        view all →
      </a>
    </div>
    <div>
      {
        recentPosts.map((post) => (
          <a href={`/posts/${post.id}`} class="post-row">
            <time
              class="font-mono text-xs"
              style="color: var(--ctp-sapphire);"
              datetime={post.data.date.toISOString()}
            >
              {post.data.date.toISOString().slice(0, 10)}
            </time>
            <h3 class="post-row-title mt-1 font-mono text-base font-bold">
              {post.data.title}
            </h3>
            {post.data.description && (
              <p class="mt-1 text-sm" style="color: var(--ctp-subtext0);">
                {post.data.description}
              </p>
            )}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Rewrite build-time dates to live relative times (e.g. "3h ago").
  (function () {
    document.querySelectorAll("[data-reltime]").forEach(function (el) {
      var iso = el.getAttribute("data-reltime");
      if (!iso) return;
      var diff = Date.now() - new Date(iso).getTime();
      if (isNaN(diff) || diff < 0) return;
      var mins = Math.floor(diff / 60000);
      var text;
      if (mins < 1) text = "just now";
      else if (mins < 60) text = mins + "m ago";
      else if (mins < 60 * 24) text = Math.floor(mins / 60) + "h ago";
      else text = Math.floor(mins / (60 * 24)) + "d ago";
      el.textContent = text;
    });
  })();
</script>
