---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@components/layout/SectionHeading.astro";
import PostsSearch from "@components/react/PostsSearch";

const all = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const entries = all.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date.toISOString(),
  tags: entry.data.tags,
  isTil: entry.data.tags.includes("til"),
}));

const description =
  "Posts and TIL notes on Kubernetes, AWS, Terraform, and platform engineering — long-form write-ups plus short notes worth remembering.";
---

<BaseLayout title="Posts — Samuel Wibrow" description={description}>
  <SectionHeading title="posts" subtitle="Long-form write-ups and TIL notes">
    <PostsSearch entries={entries} client:only="react" />

    <noscript>
      <div>
        {
          entries.map((entry) => (
            <a href={`/posts/${entry.slug}`} class="post-row">
              <div class="flex items-center gap-2">
                <time
                  class="font-mono text-xs"
                  style="color: var(--ctp-sapphire);"
                  datetime={entry.date}
                >
                  {entry.date.slice(0, 10)}
                </time>
                {entry.isTil && (
                  <span
                    class="rounded px-1.5 py-0.5 font-mono text-[0.6rem] font-bold uppercase"
                    style="background-color: var(--ctp-yellow); color: var(--ctp-base);"
                  >
                    til
                  </span>
                )}
                {entry.tags
                  .filter((t) => t !== "til")
                  .map((tag) => (
                    <span
                      class="hidden font-mono text-xs sm:inline"
                      style="color: var(--ctp-overlay0);"
                    >
                      #{tag}
                    </span>
                  ))}
              </div>
              <h2 class="post-row-title mt-1 font-mono text-base font-bold">
                {entry.title}
              </h2>
              {entry.description && (
                <p class="mt-1 text-sm" style="color: var(--ctp-subtext0);">
                  {entry.description}
                </p>
              )}
            </a>
          ))
        }
      </div>
    </noscript>
  </SectionHeading>
</BaseLayout>
