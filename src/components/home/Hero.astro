---
import MountainBackdrop from "./MountainBackdrop.astro";
import NetworkBackground from "./NetworkBackground";
---

<section class="hero">
  <MountainBackdrop />
  <NetworkBackground client:only="react" />

  <div class="hero-content">
    <h1 class="hero-title">Samuel Wibrow</h1>
    <p class="hero-subtitle">SRE by trade, over-engineer by nature</p>

    <div class="hero-socials">
      <a
        href="https://github.com/swibrow"
        target="_blank"
        rel="noopener noreferrer"
        title="GitHub"
        class="social-link"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/samuelwibrow/"
        target="_blank"
        rel="noopener noreferrer"
        title="LinkedIn"
        class="social-link"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
        </svg>
      </a>
      <a
        href="https://www.strava.com/athletes/21868831"
        target="_blank"
        rel="noopener noreferrer"
        title="Strava"
        class="social-link"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    overflow: hidden;
    padding: 4rem 0;
  }
  @media (min-width: 768px) {
    .hero {
      padding: 6rem 0;
    }
  }
  .hero-content {
    position: relative;
    z-index: 10;
    margin: 0 auto;
    max-width: 64rem;
    padding: 0 1rem;
    text-align: center;
  }
  .hero-title {
    margin-bottom: 1rem;
    font-family: "Fira Mono", ui-monospace, monospace;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--ctp-green);
    animation: hero-fade-in 0.6s ease-out both;
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 4rem; }
  }
  @media (min-width: 1024px) {
    .hero-title { font-size: 5rem; }
  }
  .hero-subtitle {
    margin-bottom: 2rem;
    font-family: "Fira Mono", ui-monospace, monospace;
    font-size: 1.125rem;
    color: var(--ctp-subtext1);
    animation: hero-fade-in 0.6s ease-out 0.2s both;
  }
  @media (min-width: 768px) {
    .hero-subtitle { font-size: 1.25rem; }
  }
  @media (min-width: 1024px) {
    .hero-subtitle { font-size: 1.5rem; }
  }
  .hero-socials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    animation: hero-fade-in 0.6s ease-out 0.4s both;
  }
  .social-link {
    color: var(--ctp-subtext1);
    transition: color 0.2s ease;
  }
  .social-link:hover {
    color: var(--ctp-green);
  }
  .social-link svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  @media (min-width: 768px) {
    .social-link svg { width: 1.5rem; height: 1.5rem; }
  }
  @media (min-width: 1024px) {
    .social-link svg { width: 1.75rem; height: 1.75rem; }
  }
  @keyframes hero-fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
