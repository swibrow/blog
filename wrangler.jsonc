{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "wibrow-dev",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    { "pattern": "wibrow.dev/*", "zone_name": "wibrow.dev" },
    { "pattern": "samuel.wibrow.dev/*", "zone_name": "wibrow.dev" }
  ],
  "observability": {
    "enabled": true
  }
}
